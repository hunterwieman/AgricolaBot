__pycache__/
*.pyc
.pytest_cache/
.DS_Store
.Rhistory

# Claude Code local settings (per-machine, per-developer)
.claude/settings.local.json

# CMA-ES pickled state files — large binary blobs (28-240KB each), can be
# regenerated by re-running tuning if a resume is ever needed. The
# human-readable .json and .log siblings are committed.
tuned_configs/*.cma.pkl
# Atomic-write temp files used by tune_heuristic.py's save_cma_state.
tuned_configs/*.cma.pkl.tmp
# Manual backups / preserved snapshots of tuned configs — local-only.
tuned_configs/*.PRESERVE.json
tuned_configs/*BACKUP*.json

# Copyrighted Agricola rulebook PDFs — kept locally for reference, not for distribution.
Rulebooks/

# Superseded historical docs — kept locally, not shipped.
archive/

# Debug game traces dumped at the repo root by play_web.py / play.py.
agricola-trace-seed*.json

# Local debug scratch script (not part of the engine or test suite).
_replay_fence_debug.py

# NN training datasets — generated artifacts, often >100MB per production run.
# Deterministic from (code_sha, base_seed, approved_configs) per FIRST_NN.md §6.8,
# so re-runnable rather than checked in. Each run dir under data/nn_training/runs/
# has its own metadata.json + games/worker_NN.pkl(.tmp) files.
data/nn_training/

# Search-agent tournament results — per-game JSONL, regenerable from the
# deterministic plan (plan_seed, base_seed) by scripts/run_search_tournament.py.
data/tournaments/

# Defensive belt-and-suspenders: any atomic-write temp files left behind by
# generation or training scripts. The broader data/nn_training/ rule above
# already masks the dataset variant; these cover nn_models/ and stray cases.
nn_models/**/*.tmp
nn_models/**/*.pt.tmp

# C++ engine port (CPP_ENGINE_PLAN.md): compiled build artifacts + the
# C++-emitted self-play JSON traces (regenerable). Source under cpp/ is tracked.
cpp/build/
data/selfplay_traces/

# Stage 5 TorchScript exports for the C++ engine (regenerable from the .pt
# checkpoints via scripts/nn/export_torchscript.py).
nn_models/cpp_export/

# Joint + value-sweep C++ inference exports — regenerable raw-weight blobs, like
# the cpp_export/ rule above (export_weights.py --out-dir nn_models/cpp_export_*).
nn_models/cpp_export_*/
# Eval match logs + per-game progress (regenerable; scripts/nn/run_cpp_match.py etc.).
eval_out/
# Stray top-level training-run stdout logs (the per-run train_log.jsonl INSIDE each
# run dir is still tracked; this only covers nn_models/<name>.log redirects).
nn_models/*.log
# Throwaway bs=8192 LR-validation run (the kept model is sp_v_256x2_bs8192/).
nn_models/sp_v_lr_*/
# Model-dir artifacts: commit only the essentials (best.pt, best.meta.json,
# config.json, train_log.jsonl, norm_stats.json, test_metrics.json, *.png).
# The --save-all-epochs checkpoints and per-run stdout logs are not tracked.
nn_models/**/epoch_*.pt
nn_models/**/epoch_*.meta.json
nn_models/**/train_stdout.log
# Dead / superseded run dirs (kept on disk for reference, not tracked).
nn_models/joint_taper128_117k/
nn_models/joint_taper128_117k_stream/
nn_models/_ramtest_stream/
# Pooled-data experiments (margin + outcome target) — results in REGISTRY.md.
nn_models/pooled_all_thin/
nn_models/pooled_all_thin_p20/
nn_models/pooled_all_thin_outcome/
nn_models/_pooled_all_thin_outcome_dropout0_aborted/
# Data-variation experiment arms (visit / Q-selection / candidate-encoder).
nn_models/exp_cand_t1/
nn_models/exp_cand_t2/
nn_models/exp_q_t0005/
nn_models/exp_q_t001/
nn_models/exp_q_t002/
nn_models/exp_visit_t07/
nn_models/exp_visit_t10/
nn_models/exp_visit_combined/train_log.jsonl

# Regret-sweep diagnostic artifacts (regenerable via scripts/replay_regret_sweep.py)
regret_out/

# Cloud c_uct sweep artifacts (regenerable via scripts/cloud_cuct_sweep.sh)
sweep_out/
sweep_driver_*.log
sweep_out_driver.log
sweep_progress.log
